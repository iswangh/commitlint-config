{
  "name": "@iswangh/commitlint-config",
  "type": "module",
  "version": "0.2.0",
  "description": "基于 @commitlint/config-conventional 的 Commitlint 配置，提供默认值和覆盖支持",
  "author": "iswangh <https://gitee.com/iswangh>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/iswangh/commitlint-config.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "commitlint",
    "commitlint-config",
    "@commitlint/config-conventional",
    "conventional-commits"
  ],
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.js"
    }
  },
  "main": "./index.js",
  "files": [
    "README.md",
    "index.js",
    "index.ts",
    "src"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "release": "cross-env CI=true semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "peerDependencies": {
    "@commitlint/config-conventional": "^20.0.0"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@iswangh/eslint-config": "^0.2.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^1.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "semantic-release": "^25.0.2",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "25.1.0"
  }
}
